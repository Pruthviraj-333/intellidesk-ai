# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string-in-production
JWT_SECRET_KEY=change-me-to-another-random-32-char-string

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://intellidesk:intellidesk_password@postgres:5432/intellidesk
DB_PASSWORD=intellidesk_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ─── AI — Groq API ────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Email — Gmail SMTP ───────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# Instructions: https://support.google.com/accounts/answer/185833
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_FROM_NAME=IntelliDesk AI

# ─── Cloudinary (File Storage) ────────────────────────────────────────────────
# Get free account at: https://cloudinary.com
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── App ──────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=25
TOKEN_EXPIRY_HOURS=24

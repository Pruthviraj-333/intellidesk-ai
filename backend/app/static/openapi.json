                  "session_uuid": { "type": "string", "example": "123e4567-e89b-12d3-a456-426614174000" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI assistant response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "response": { "type": "string", "example": "To connect to the VPN, make sure you download Cisco AnyConnect..." },
                        "session_uuid": { "type": "string" },
                        "sources": { "type": "array", "items": { "type": "object" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
